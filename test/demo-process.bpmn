<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0-dev">
  <bpmn:process id="ResourceSuggestDemo" name="Resource Suggest Demo" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Order Received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDef_1" messageRef="Message_OrderReceived" />
    </bpmn:startEvent>
    <bpmn:businessRuleTask id="EvaluateDiscount" name="Evaluate Discount" camunda:decisionRef="DiscountDecision">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:businessRuleTask id="AssessRisk" name="Assess Risk" camunda:decisionRef="RiskAssessment">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:callActivity id="ProcessPayment" name="Process Payment" calledElement="PaymentProcess">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:userTask id="ReviewOrder" name="Review Order" camunda:formRef="OrderReviewForm">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:callActivity id="ShipOrder" name="Ship Order" calledElement="ShippingProcess">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="EndEvent_1" name="Order Completed">
      <bpmn:incoming>Flow_6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="EvaluateDiscount" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="EvaluateDiscount" targetRef="AssessRisk" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="AssessRisk" targetRef="ProcessPayment" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="ProcessPayment" targetRef="ReviewOrder" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="ReviewOrder" targetRef="ShipOrder" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="ShipOrder" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmn:message id="Message_OrderReceived" name="order-received" />
  <bpmn:message id="Message_PaymentCompleted" name="payment-completed" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="ResourceSuggestDemo">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="179" y="109" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="155" y="152" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EvaluateDiscount_di" bpmnElement="EvaluateDiscount">
        <dc:Bounds x="270" y="87" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AssessRisk_di" bpmnElement="AssessRisk">
        <dc:Bounds x="430" y="87" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ProcessPayment_di" bpmnElement="ProcessPayment">
        <dc:Bounds x="590" y="87" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReviewOrder_di" bpmnElement="ReviewOrder">
        <dc:Bounds x="750" y="87" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ShipOrder_di" bpmnElement="ShipOrder">
        <dc:Bounds x="910" y="87" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1072" y="109" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1048" y="152" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="215" y="127" />
        <di:waypoint x="270" y="127" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="370" y="127" />
        <di:waypoint x="430" y="127" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="530" y="127" />
        <di:waypoint x="590" y="127" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="690" y="127" />
        <di:waypoint x="750" y="127" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="850" y="127" />
        <di:waypoint x="910" y="127" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="1010" y="127" />
        <di:waypoint x="1072" y="127" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
